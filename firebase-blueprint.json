{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user information stored in users/{userId}",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Customers, leads, and vendors",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["lead", "customer", "vendor"] },
        "status": { "type": "string" },
        "company": { "type": "string" },
        "address": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "ownerId"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing documents",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "contactId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue", "cancelled"] },
        "total": { "type": "number" },
        "tax": { "type": "number" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["number", "contactId", "status", "total", "ownerId"]
    },
    "Project": {
      "title": "Project",
      "description": "Management units",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "ownerId"]
    },
    "Task": {
      "title": "Task",
      "description": "Project tasks",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "review", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assignedTo": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["projectId", "title", "status", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "CRM Contacts"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Project tasks"
    }
  }
}
